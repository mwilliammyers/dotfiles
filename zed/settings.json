// Zed settings
// https://zed.dev/docs/configuring-zed
{
  "theme": "One Dark Pro",
  "vim_mode": true,
  "ui_font_size": 13.5,
  "buffer_font_size": 13.0,
  "show_whitespaces": "selection",
  "remove_trailing_whitespace_on_save": false,
  "ensure_final_newline_on_save": false,
  "wrap_guides": [80, 100, 120],
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "format_on_save": "off",
  "terminal": { "dock": "right" },
  "languages": {
    "Rust": {
      "format_on_save": "on"
    },
    "Python": {
      "language_servers": ["ty", "basedpyright", "ruff"],
      "format_on_save": "on"
    }
  },
  // "lsp": {
  //   "ty": {
  //     "binary": {
  //       "path": "uv",
  //       "arguments": ["run", "--active", "ty", "server"]
  //     }
  //   },
  //   "ruff": {
  //     "binary": {
  //       "path": "uv",
  //       "arguments": ["run", "--active", "ruff", "server"]
  //     }
  //   }
  // },
  "language_models": {
    "openai_compatible": {
      "Martian": {
        "api_url": "https://api.withmartian.com/v1",
        "available_models": [
          {
            "name": "anthropic/claude-sonnet-4-5",
            "max_tokens": 200000,
            "max_completion_tokens": 200000
          },
          {
            "name": "openai/gpt-5",
            "max_tokens": 200000,
            "max_completion_tokens": 200000
          },
          {
            "name": "google/gemini-2.5-pro",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000
          },
          {
            "name": "google/gemini-2.5-flash",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000
          }
        ]
      }
    }
  },
  "agent_servers": {
    "claude": {
      "default_mode": "acceptEdits"
    },
    "OpenCode": {
      "favorite_models": [
        "martian-anthropic/anthropic/claude-sonnet-4-6",
        "martian-anthropic/anthropic/claude-opus-4-6",
        "martian-openai/x-ai/grok-code-fast-1:optimized"
      ],
      "type": "custom",
      "command": "opencode",
      "args": ["acp"]
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5-thinking-latest"
    }
  },
  // "edit_predictions": {
  //   "mode": "subtle"
  // },
  "file_scan_inclusions": [
    ".env*",
    "*/tmp/"
  ],
  "telemetry": { "diagnostics": false, "metrics": false }
}
